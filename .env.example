# Nexus Sports Environment Configuration
# Copy this file to .env and adjust values as needed.

# Environment mode: development | production
ENVIRONMENT=development

# CORS allowed origins (comma-separated)
# In production, restrict to your frontend domain only.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Data storage paths
DATA_DIR=data
ARCHIVE_DIR=data/archived_files

# Database connection
# SQLite (default):
DATABASE_URL=sqlite:///./data/nexus_sports.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/nexus_sports

# Upload limits (in MB)
MAX_UPLOAD_SIZE_MB=50

# Backend API URL (used by watcher service)
BACKEND_API_URL=http://localhost:8000/api/v1

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
